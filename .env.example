# fitness.duyari.com.tr / Canlı sunucu - Yarın dolduracaksın
# Bu dosyayı .env olarak kopyala ve değerleri gir: cp .env.example .env

NODE_ENV=production
PORT=3000
CORS_ORIGIN=*

# Veritabanı (sunucu panelinden MySQL oluştur, bilgileri buraya yaz)
DB_HOST=localhost
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=3306

# JWT - rastgele uzun stringler (örn. openssl rand -hex 32)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CLIENT_TOKEN=

# Apple Sign In
APPLE_TEAM_ID=
APPLE_CLIENT_ID=
APPLE_KEY_ID=
APPLE_ISSUER_ID=
APPLE_PRIVATE_KEY_PATH=

# OneSignal
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# Bunny CDN (videolar)
BUNNY_CDN_PULL_ZONE=
BUNNY_CDN_STORAGE_ZONE=
BUNNY_CDN_API_KEY=
BUNNY_CDN_USERNAME=
