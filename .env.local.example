# Yerel geliştirme için bu dosyayı .env.local olarak kopyalayın:
#   cp .env.local.example .env.local
# .env.local varsa server.js bunu yükler ve .env değerlerini override eder.
# Böylece .env (canlı DB) dokunulmadan yerelde localhost MySQL kullanılır.

# Yerel MySQL (Mac: Homebrew ile kurulum: brew install mysql && brew services start mysql)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=flywork1_fitgym
DB_PORT=3306
